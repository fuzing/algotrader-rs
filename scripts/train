#!/usr/bin/env bash

#
# Originally we started with 8 heads and 4 layers
# export CUBECL_AUTOTUNE_LEVEL=0
cargo run --bin train -- --spec-file=KHC-spec.json \
  --dataset-file=KHC-train.csv \
  --batch-size=128 \
  --num-epochs=10 \
  --dropout=0.1 \
  --shuffle-seed=42 \
  --transformer-heads=8 \
  --transformer-layers=8 \
  --feed-forward-size=1024 \
  --artifacts-folder=/run/media/peter/genetics/algotrader/data/KHC-artifacts


