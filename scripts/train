#!/usr/bin/env bash

# export CUBECL_AUTOTUNE_LEVEL=0
cargo run --bin train -- --spec-file=KHC-spec.json \
  --dataset-file=KHC-train.csv \
  --batch-size=64 \
  --num-epochs=10 \
  --dropout=0.1 \
  --shuffle-seed=50 \
  --transformer-heads=8 \
  --transformer-layers=4 \
  --feed-forward-size=1024 \
  --artifacts-folder=/run/media/peter/genetics/algotrader/data/artifacts


