#!/usr/bin/env bash

cargo run --bin extractor --  --prediction-intervals=128 --patch-intervals=4 --patch-stride=4 --gain-percentage=0.05 --loss-percentage=0.05 \
  --lob-levels=15 --pretty --start-date=2024-12-02 --end-date=2024-12-02 \
  --output-csv=/run/media/peter/genetics/algotrader/data/KHC-train.csv \
  --output-spec=/run/media/peter/genetics/algotrader/data/KHC-spec.json \
  --extraction-interval-nanos=250000000 --holding-time-seconds=2 'KHC-XNAS.ITCH-2024-01-01 00:00:00 UTC-2024-12-31 23:59:59 UTC-mbo.dbn.zst'

